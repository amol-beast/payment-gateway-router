# Real ICICI UAT sandbox credentials for tests/Browser/IciciLiveSandboxTest.php.
#
# These are secrets tied to a live external system - never commit real values.
# Copy this file to .env.testing.local (gitignored) and fill it in with the
# attributes from the ICICI_TEST row in the pg_connections table (dev DB).
# Without this file, the live sandbox test skips itself automatically.

ICICI_TEST_MERCHANT_ID=
ICICI_TEST_AGGREGATOR_ID=
ICICI_TEST_ENCRYPTION_KEY=
ICICI_TEST_SUB_MERCHANT_ID=
ICICI_TEST_PAYMODE=

# Real Razorpay test-mode credentials for tests/Browser/RazorpayLiveSandboxTest.php.
# Fill in from the RAZORPAY row in the pg_connections table (dev DB).
RAZORPAY_TEST_KEY_ID=
RAZORPAY_TEST_KEY_SECRET=

# Real Cashfree test-mode credentials for tests/Browser/CashfreeLiveSandboxTest.php.
# Fill in from the CASHFREE row in the pg_connections table (dev DB).
CASHFREE_TEST_KEY_ID=
CASHFREE_TEST_KEY_SECRET=

# Real PayPal sandbox credentials for tests/Browser/PayPalLiveSandboxTest.php.
# client_id/secret come from the PAYPAL row in the pg_connections table (dev DB).
# buyer_email/buyer_password are a PayPal Sandbox *personal* (buyer) account,
# created in the PayPal Developer Dashboard, used to actually approve the
# payment on PayPal's hosted checkout page. Without these two, the test still
# runs up to landing on PayPal's checkout page but skips completing payment.
PAYPAL_TEST_CLIENT_ID=
PAYPAL_TEST_SECRET=
PAYPAL_TEST_BUYER_EMAIL=
PAYPAL_TEST_BUYER_PASSWORD=

# Real Stripe test-mode credentials for tests/Browser/StripeLiveSandboxTest.php.
# Fill in from the STRIPE row in the pg_connections table (dev DB).
STRIPE_TEST_KEY_SECRET=
