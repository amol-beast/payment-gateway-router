# Real ICICI UAT sandbox credentials for tests/Browser/IciciLiveSandboxTest.php.
#
# These are secrets tied to a live external system - never commit real values.
# Copy this file to .env.testing.local (gitignored) and fill it in with the
# attributes from the ICICI_TEST row in the pg_connections table (dev DB).
# Without this file, the live sandbox test skips itself automatically.

ICICI_TEST_MERCHANT_ID=
ICICI_TEST_AGGREGATOR_ID=
ICICI_TEST_ENCRYPTION_KEY=
ICICI_TEST_SUB_MERCHANT_ID=
ICICI_TEST_PAYMODE=
